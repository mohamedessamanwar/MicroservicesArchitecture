{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Payment.Api.BackgroundServices.RabbitMqListenerService": "Information"
    }
  },
  "ConnectionStrings": {
    "PaymentDatabase": "Host=write-db;Port=5432;Database=Paymentdb;Username=admin;Password=pass;",
    "Redis": "redis:6379"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "admin",
    "Password": "admin123",
    "Exchange": "cdc.exchange",
    "RoutingKey": "payment-server.public.#"
  },
  "Services": {
    "OrderService": "http://order-service:8080"
  },
  "OutboundHttp": {
    "Defaults": {
      "MaxConnectionsPerServer": 64,
      "PooledConnectionLifetimeSeconds": 300,
      "PooledConnectionIdleTimeoutSeconds": 120,
      "ConnectTimeoutSeconds": 10,
      "OverallRequestTimeoutSeconds": 100,
      "MaxParallelRequests": 128,
      "MaxQueuedRequests": 256
    },
    "Clients": {
      "OrderService": {
        "Pipelines": {
          "Critical": {
            "TimeoutSeconds": 10,
            "RetryAttempts": 2,
            "EnableRetry": true,
            "EnableCircuitBreaker": true
          },
          "NoRetry": {
            "TimeoutSeconds": 10,
            "RetryAttempts": 0,
            "EnableRetry": false,
            "EnableCircuitBreaker": true
          },
          "Health": {
            "TimeoutSeconds": 2,
            "RetryAttempts": 1,
            "EnableRetry": true,
            "EnableCircuitBreaker": false
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
