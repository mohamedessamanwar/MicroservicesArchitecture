{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "OrderService.Infrastructure.Messaging": "Debug"
    }
  },
  "ConnectionStrings": {
    "Egypt": {
      "Primary": "Host=Write-db;Port=5432;Database=OrderDb;Username=admin;Password=pass;",
      "Replica": "Host=read-db;Port=5432;Database=OrderDb;Username=admin;Password=pass;"
    },
    "UAE": {
      "Primary": "Host=Write-db-uae;Port=5432;Database=OrderDb;Username=admin;Password=pass;",
      "Replica": "Host=read-db-uae;Port=5432;Database=OrderDb;Username=admin;Password=pass;"
    }
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "admin",
    "Password": "admin123",
    "Exchange": "cdc.exchange",
    "RoutingKey": "order-server.public.#",
    "QueueName": "order.write.cdc.q",
    "RetryCount": 5,
    "RetryDelaySeconds": 5,
    "DeadLetterExchange": "cdc.dlx",
    "DeadLetterQueue": "order.write.cdc.dlq",
    "DeadLetterRoutingKey": "order.write.cdc.dlq",
    "MessageTtlMs": 86400000,
    "MaxLength": 50000
  },
  "Messaging": {
    "Providers": [
      {
        "Name": "BillingBroker",
        "Host": "rabbitmq",
        "Port": 5672,
        "VirtualHost": "/",
        "Username": "admin",
        "Password": "admin123",
        "HeartbeatSeconds": 30
      }
    ]
  },
  "Services": {
    "PaymentService": "http://payment-service:8080"
  },
  "OutboundHttp": {
    "Defaults": {
      "MaxConnectionsPerServer": 64,
      "PooledConnectionLifetimeSeconds": 300,
      "PooledConnectionIdleTimeoutSeconds": 120,
      "ConnectTimeoutSeconds": 10,
      "OverallRequestTimeoutSeconds": 100,
      "MaxParallelRequests": 128,
      "MaxQueuedRequests": 256
    },
    "Clients": {
      "PaymentService": {
        "Pipelines": {
          "Read": {
            "TimeoutSeconds": 8,
            "RetryAttempts": 2,
            "EnableRetry": true,
            "EnableCircuitBreaker": true
          },
          "NoRetry": {
            "TimeoutSeconds": 12,
            "RetryAttempts": 0,
            "EnableRetry": false,
            "EnableCircuitBreaker": true
          },
          "Critical": {
            "TimeoutSeconds": 15,
            "RetryAttempts": 2,
            "EnableRetry": true,
            "EnableCircuitBreaker": true
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
